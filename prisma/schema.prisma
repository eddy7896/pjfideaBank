generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id             String   @id @default(cuid())
  name           String   @unique
  location       String
  subGeographyId String?
  address        String
  phone          String
  website        String?
  principalName  String
  udaiseCode     String   @unique
  createdAt      DateTime @default(now())
  createdBy      String?

  subGeography SubGeography? @relation(fields: [subGeographyId], references: [id])
  teams        StudentTeam[]
  ideas        Idea[]

  @@index([subGeographyId])
}

model User {
  id             Int           @id @default(autoincrement())
  role           String
  schoolName     String?
  displayName    String
  email          String        @unique
  passwordHash   String?
  teamId         String?
  geographyId    String?
  subGeographyId String?
  assignedLeadId String?
  createdAt      DateTime      @default(now())

  geography    Geography?    @relation(fields: [geographyId], references: [id])
  subGeography SubGeography? @relation(fields: [subGeographyId], references: [id])

  @@index([geographyId])
  @@index([subGeographyId])
}

model TeamMember {
  id            String   @id @default(cuid())
  studentTeamId String
  name          String
  grade         String
  contactNumber String
  gender        String

  studentTeam StudentTeam @relation(fields: [studentTeamId], references: [id], onDelete: Cascade)
}

model StudentTeam {
  id         String   @id
  pin        String
  name       String
  schoolName String
  createdAt  DateTime @default(now())

  members TeamMember[]
  ideas   Idea[]
  school  School     @relation(fields: [schoolName], references: [name])

  @@index([schoolName])
}

model Idea {
  id               String   @id
  schoolName       String
  title            String
  theme            String
  teamId           String?
  studentTeam      String
  problemStatement String
  targetAudience   String
  status           String
  lastUpdated      String
  stageData        Json?
  createdAt        DateTime @default(now())

  school   School       @relation(fields: [schoolName], references: [name])
  team     StudentTeam? @relation(fields: [teamId], references: [id])
  timeline TimelineEvent[]

  @@index([schoolName])
  @@index([teamId])
}

model TimelineEvent {
  id        String   @id
  ideaId    String
  type      String
  stage     String?
  fromStage String?
  toStage   String?
  content   String?
  author    String?
  timestamp String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
}

model ThemeActivity {
  id          String   @id
  date        Int
  month       Int
  year        Int
  title       String
  theme       String
  schoolName  String?
  description String?
  createdAt   DateTime @default(now())

  @@index([month])
  @@index([year])
}

model ActivityReport {
  id                String   @id @default(cuid())
  activityId        String
  schoolName        String
  teacherName       String
  sessionDate       String
  timeIn            String
  timeOut           String
  grades            String
  totalStudents     Int
  boysCount         Int
  girlsCount        Int
  lcmsCode          String?
  topicsLessons     String
  learningGoal      String
  materials         Json
  safetyBriefing    Boolean
  ppeWorn           Boolean
  labCleanup        Boolean
  incidentNotes     String?
  studentEngagement String
  successes         String
  challenges        String
  followUpActions   String
  createdAt         DateTime @default(now())
  submittedBy       String

  @@index([schoolName])
  @@index([activityId])
}

model Geography {
  id        String          @id @default(cuid())
  name      String          @unique
  code      String          @unique
  createdAt DateTime        @default(now())
  
  subGeographies SubGeography[]
  users          User[]
}

model SubGeography {
  id          String    @id @default(cuid())
  name        String
  geographyId String
  createdAt   DateTime  @default(now())

  geography Geography @relation(fields: [geographyId], references: [id], onDelete: Cascade)
  schools   School[]
  users     User[]

  @@unique([name, geographyId])
  @@index([geographyId])
}
