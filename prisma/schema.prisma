// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id            String   @id @default(cuid())
  name          String   @unique
  location      String
  address       String
  phone         String
  website       String?
  principalName String
  udaiseCode    String   @unique
  createdAt     DateTime @default(now())
  createdBy     String?

  teams  StudentTeam[]
  ideas  Idea[]
  users  User[]
}

model User {
  id          Int      @id @default(autoincrement())
  role        String   // 'super-admin' | 'school' | 'education-dept' | 'student'
  schoolName  String?
  displayName String
  email       String   @unique
  teamId      String?
  createdAt   DateTime @default(now())

  school StudentTeam? @relation(fields: [schoolName], references: [name])
}

model TeamMember {
  id              String   @id @default(cuid())
  studentTeamId   String
  name            String
  grade           String
  contactNumber   String
  gender          String   // 'Male' | 'Female' | 'Non-binary' | 'Prefer not to say'

  studentTeam StudentTeam @relation(fields: [studentTeamId], references: [id], onDelete: Cascade)
}

model StudentTeam {
  id         String   @id
  pin        String
  name       String
  schoolName String
  createdAt  DateTime @default(now())

  members TeamMember[]
  ideas   Idea[]
  school  School     @relation(fields: [schoolName], references: [name])
}

model Idea {
  id                String   @id
  schoolName        String
  title             String
  theme             String
  teamId            String?
  studentTeam       String
  problemStatement  String
  targetAudience    String
  status            String   // Design Thinking status
  lastUpdated       String
  stageData         Json?    // JSON data for stages
  createdAt         DateTime @default(now())

  school     School       @relation(fields: [schoolName], references: [name])
  team       StudentTeam? @relation(fields: [teamId], references: [id])
  timeline   TimelineEvent[]
}

model TimelineEvent {
  id        String   @id
  ideaId    String
  type      String   // 'created' | 'stage_change' | 'form_submitted' | 'comment' | 'test_failed'
  stage     String?
  fromStage String?
  toStage   String?
  content   String?
  author    String?
  timestamp String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model ThemeActivity {
  id          String   @id
  date        Int      // 1-31
  month       Int      // 0-11
  year        Int
  title       String
  theme       String
  schoolName  String?
  description String?
  createdAt   DateTime @default(now())
}
