generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id             String   @id @default(cuid())
  name           String   @unique
  location       String
  subGeographyId String?
  address        String
  phone          String
  website        String?
  principalName  String
  udaiseCode     String   @unique
  createdAt      DateTime @default(now())
  createdBy      String?

  subGeography SubGeography? @relation(fields: [subGeographyId], references: [id])
  schoolUsers  User[]         @relation("UserSchool")
  teams        StudentTeam[]  @relation("StudentTeamSchoolById")
  ideas        Idea[]         @relation("IdeaSchoolById")

  @@index([subGeographyId])
}

model User {
  id             Int           @id @default(autoincrement())
  role           String
  schoolName     String?
  schoolId       String?
  displayName    String
  email          String        @unique
  passwordHash   String?
  teamId         String?
  geographyId    String?
  subGeographyId String?
  assignedLeadId     String?  // DEPRECATED: legacy email string, kept for back-compat reads. Use assignedLeadUserId.
  assignedLeadUserId Int?
  createdAt          DateTime @default(now())
  createdById        Int?

  geography           Geography?         @relation(fields: [geographyId], references: [id])
  subGeography        SubGeography?      @relation(fields: [subGeographyId], references: [id])
  school              School?            @relation("UserSchool", fields: [schoolId], references: [id], onDelete: SetNull)
  assignedSubGeos     UserSubGeography[]
  createdBy           User?              @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers        User[]             @relation("UserCreatedBy")
  assignedLead        User?              @relation("AssignedLead", fields: [assignedLeadUserId], references: [id], onDelete: SetNull)
  assignedTrainers    User[]             @relation("AssignedLead")

  @@index([geographyId])
  @@index([subGeographyId])
  @@index([schoolId])
  @@index([role])
  @@index([assignedLeadUserId])
}

// Many-to-many join so a geography-lead can be assigned to several
// districts within their state. Coexists with `User.subGeographyId` for
// the legacy single-district case; new geography-lead assignments use
// this join exclusively.
model UserSubGeography {
  userId         Int
  subGeographyId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subGeography SubGeography @relation(fields: [subGeographyId], references: [id], onDelete: Cascade)

  @@id([userId, subGeographyId])
  @@index([subGeographyId])
}

model TeamMember {
  id            String   @id @default(cuid())
  studentTeamId String
  name          String
  grade         String
  contactNumber String
  gender        String

  studentTeam StudentTeam @relation(fields: [studentTeamId], references: [id], onDelete: Cascade)
}

model StudentTeam {
  id         String   @id @default(cuid())
  pin        String
  name       String
  // Denormalized snapshot of School.name kept for display + legacy queries.
  // Authoritative FK is `schoolId`. There is no `@relation` here so renaming
  // the school does not require cascading text updates.
  schoolName String
  schoolId   String
  createdAt  DateTime @default(now())

  members TeamMember[]
  ideas   Idea[]
  school  School       @relation("StudentTeamSchoolById", fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolName, pin])
  @@index([schoolName])
  @@index([schoolId])
}

model Idea {
  id               String   @id @default(cuid())
  // Denormalized snapshot of School.name. The authoritative FK is `schoolId`.
  schoolName       String
  schoolId         String
  title            String
  theme            String
  teamId           String?
  // Denormalized snapshot of team name. Kept for display when teamId is null.
  studentTeam      String
  problemStatement String
  targetAudience   String
  status           String
  lastUpdated      DateTime @default(now()) @updatedAt
  stageData        Json?
  createdAt        DateTime @default(now())

  school   School       @relation("IdeaSchoolById", fields: [schoolId], references: [id], onDelete: Cascade)
  team     StudentTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  timeline TimelineEvent[]

  @@index([schoolName])
  @@index([schoolId])
  @@index([teamId])
}

model TimelineEvent {
  id        String   @id @default(cuid())
  ideaId    String
  type      String
  stage     String?
  fromStage String?
  toStage   String?
  content   String?
  author    String?
  timestamp DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([timestamp])
}

model Theme {
  id          String   @id @default(cuid())
  month       String   @unique
  shortMonth  String
  theme       String
  description String?
  icon        String?
  gradient    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  schoolName String?
  ip         String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model ThemeActivity {
  id          String   @id
  date        Int
  month       Int
  year        Int
  title       String
  theme       String
  schoolName  String?
  description String?
  createdAt   DateTime @default(now())

  @@index([month])
  @@index([year])
}

model ActivityReport {
  id                String   @id @default(cuid())
  activityId        String
  schoolName        String
  teacherName       String
  sessionDate       String
  timeIn            String
  timeOut           String
  grades            String
  totalStudents     Int
  boysCount         Int
  girlsCount        Int
  lcmsCode          String?
  topicsLessons     String
  learningGoal      String
  materials         Json
  safetyBriefing    Boolean
  ppeWorn           Boolean
  labCleanup        Boolean
  incidentNotes     String?
  studentEngagement String
  successes         String
  challenges        String
  followUpActions   String
  createdAt         DateTime @default(now())
  submittedBy       String

  @@index([schoolName])
  @@index([activityId])
}

model Geography {
  id        String          @id @default(cuid())
  name      String          @unique
  code      String          @unique
  createdAt DateTime        @default(now())
  
  subGeographies SubGeography[]
  users          User[]
}

model SubGeography {
  id          String    @id @default(cuid())
  name        String
  geographyId String
  createdAt   DateTime  @default(now())

  geography      Geography          @relation(fields: [geographyId], references: [id], onDelete: Cascade)
  schools        School[]
  users          User[]
  assignedLeads  UserSubGeography[]

  @@unique([name, geographyId])
  @@index([geographyId])
}
