{
  "name": "pijam-ideabank",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx prisma/seed.ts",
    "db:hash-pins": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/hash-student-pins.ts",
    "verify:phase6": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/verify-phase6.ts",
    "db:backfill-subgeo": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/backfill-school-subgeo.ts",
    "db:seed-themes": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/seed-themes.ts",
    "verify:phaseL": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/verify-phaseL.ts",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed-jk": "node --env-file=.env.local node_modules/tsx/dist/cli.mjs scripts/seed-jk-schools.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@tremor/react": "^3.18.7",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.1.7",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.11.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
